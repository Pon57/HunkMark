{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver",
  ],
  "labels": [
    "dependencies",
  ],
  "configMigration": true,
  "minimumReleaseAge": "7 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "2 days",
  },
  "packageRules": [
    {
      "description": "Track Node.js releases only after they reach LTS",
      "matchDatasources": [
        "node-version",
      ],
      "versioning": "node",
      "rangeStrategy": "replace",
    },
    {
      "matchUpdateTypes": [
        "patch",
      ],
      "automerge": true,
    },
  ],
}
